# ── DATABASE ──────────────────────────────────────────────────────────
# SQLite (default, zero config)
DATABASE_URL=sqlite:///./selfynk.db
# Postgres (optional - uncomment to switch)
# DATABASE_URL=postgresql://user:password@localhost:5432/selfynk

# ── LLM PROVIDER ──────────────────────────────────────────────────────
# Options: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (optional)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Ollama (optional - local models, no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── SERVER ────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── FRONTEND ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── FEATURE FLAGS ─────────────────────────────────────────────────────
# Auto-analyze entries on save (true = immediate, false = manual trigger)
AUTO_ANALYZE=true
# Auto-recompute brand DNA after every N new analyzed entries
BRAND_DNA_RECOMPUTE_THRESHOLD=5
